# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
env/
venv/

# Ignore all .env files anywhere in the project
**/.env

# Optional: Ignore variations like .env.local or .env.development
**/.env.*

# Ignorer tous les dossiers __pycache__ et fichiers .pyc
**/__pycache__/
**/*.pyc

# Ignorer tous les environnements virtuels Python (partout)
**/venv/
**/.venv/
**/env/
**/.env/

# Ignore all .gitignore files in subfolders
**/.gitignore

# IMPORTANT: Exception to keep your root .gitignore file tracked
!/.gitignore
